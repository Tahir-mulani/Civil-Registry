                                        <asp:HyperLink ID="HyperLink8" runat="server" CssClass="style6" 
                                            NavigateUrl="~/Admin/VoterIdapprove.aspx">Voter Card</asp:HyperLink>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                    <tr>
                        <td class="style9">
                            <asp:Image ID="Image7" runat="server" Height="40px" ImageUrl="~/Image/pan2.png" 
                                Width="50px" />
                        </td>
                        <td class="style5">
                            <asp:HyperLink ID="HyperLink9" runat="server" CssClass="style4" 
                                ForeColor="Black" NavigateUrl="~/Admin/Manage_Customer.aspx">Manage Customer</asp:HyperLink>
                        </td>
                    </tr>
                    <tr>
                        <td class="style9">
                            <asp:Image ID="Image8" runat="server" Height="40px" ImageUrl="~/Image/pan2.png" 
                                Width="50px" />
                        </td>
                        <td class="style5">
                            <asp:HyperLink ID="HyperLink10" runat="server" CssClass="style4" 
                                ForeColor="Black" NavigateUrl="~/Admin/View_Feedback.aspx">View Feedback</asp:HyperLink>
                        </td>
                    </tr>
                    <tr>
                        <td class="style9">
                            <asp:Image ID="Image9" runat="server" Height="40px" ImageUrl="~/Image/pan2.png" 
                                Width="50px" />
                        </td>
                        <td class="style5">
                            <asp:HyperLink ID="HyperLink11" runat="server" CssClass="style4" 
                                ForeColor="Black" NavigateUrl="~/Admin/Manage_admin.aspx">Manage Admin</asp:HyperLink>
                        </td>
                    </tr>
                    <tr>
                        <td class="style9">
                            <asp:Image ID="Image10" runat="server" Height="40px" 
                                ImageUrl="~/Image/pan2.png" Width="50px" />
                        </td>
                        <td class="style5">
                            <asp:HyperLink ID="HyperLink12" runat="server" CssClass="style4" 

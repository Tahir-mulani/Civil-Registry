                        <td class="style4">
                            <asp:HyperLink ID="HyperLink13" runat="server" ForeColor="Black" 
                                NavigateUrl="~/User/home.aspx">Logout</asp:HyperLink>
                        </td>
                    </tr>
                </table>
            </td>
            <td class="style11" valign="top">
                <asp:ContentPlaceHolder ID="ContentPlaceHolder1" runat="server">
                    <asp:Panel ID="Panel1" runat="server" 
                        BackImageUrl="~/Image/HD_Technologies_Banner5.jpg" Height="660px" 
                        Width="1424px">
                    </asp:Panel>
                </asp:ContentPlaceHolder>
